#!/bin/bash

API_FILE="/usr/local/sbin/zidan-api.py"
SERVICE="zidan-api"
DOMAIN=$(cat /etc/xray/domain 2>/dev/null)
IP=$(curl -sS ipv4.icanhazip.com)

clear
echo "———————————————————————————————————————"
echo "           ZIDAN HTTP API"
echo "———————————————————————————————————————"
echo ""
read -p "Input new API KEY : " NEWKEY

if [[ -z "$NEWKEY" ]]; then
  echo "API KEY tidak boleh kosong"
  exit 1
fi

if [[ ! -f "$API_FILE" ]]; then
  echo "File API tidak ditemukan: $API_FILE"
  exit 1
fi

sed -i "s|API_TOKEN = \".*\"|API_TOKEN = \"$NEWKEY\"|g" "$API_FILE"

systemctl restart "$SERVICE"

echo ""
echo "———————————————————————————————————————"
echo "API berhasil diupdate"
echo "———————————————————————————————————————"
echo "API KEY   : $NEWKEY"
echo "IP URL    : http://$IP:5888"
echo "DOMAIN    : http://$DOMAIN:5888"
echo "DOCS      : http://$IP:5888/docs"
echo "———————————————————————————————————————"
echo "Endpoint:"
echo "GET    /"
echo "POST   /ssh/create"
echo "POST   /ssh/renew"
echo "POST   /ssh/delete"
echo "POST   /ssh/unlock"
echo "POST   /ssh/trial"
echo "GET    /ssh/member"
echo "GET    /ssh/online"
echo "DELETE /ssh/expired"
echo "———————————————————————————————————————"
echo ""
read -n 1 -s -r -p "Press any key to back"
m-ftr