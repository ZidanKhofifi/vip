  echo -e " 12.) Trial Account VLess"
  echo -e " 13.) Delete Account VLess"
  echo -e " 14.) Renew Account VLess"
  echo -e " 15.) List Member VLess"
  echo -e " 16.) Edit Limit IP VLess"
  echo -e " 17.) Edit Limit Bandwidth VLess"

  baris_panjang
  echo -e " 18.) Back to Menu"
  echo -e "  x.) Exit"
