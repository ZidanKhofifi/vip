#!/bin/bash

yellow="\033[0;33m"
ungu="\033[0;35m"
Red="\033[91;1m"
Xark="\033[0m"
BlueCyan="\033[5;36m"
WhiteBe="\033[5;37m"
GreenBe="\033[5;32m"
YellowBe="\033[5;33m"
BlueBe="\033[5;34m"
# . Liner 
function baris_panjang() {
  echo -e "${BlueCyan} ——————————————————————————————————— ${Xark} "
}

function Sanz_Banner() {
clear
baris_panjang
echo -e "${ungu}               vip TUNNELING     ${Xark} "
baris_panjang
}

function Sc_Credit(){
sleep 1
baris_panjang
echo -e "${ungu}  Terimakasih Telah Menggunakan ${Xark}"
echo -e "${ungu}          Script Credit ${Xark}"
echo -e "${ungu}             vip TUNNELING ${Xark}"
baris_panjang
exit 1
}

duration=6
frames=("██10%" "█████35%" "█████████65%" "█████████████80%" "█████████████████████90%" "█████████████████████████100%")

# Menghitung jumlah frame
num_frames=${#frames[@]}

# Menghitung jumlah iterasi
num_iterations=$((duration))

# Fungsi untuk menampilkan animasi loading berwarna

Loading_Animasi() {
    for ((i = 0; i < num_iterations; i++)); do
        clear
        index=$((i % num_frames))
        color_code=$((31 + i % 7))
echo ""
echo ""
echo ""
echo -e "\e[1;${color_code}m ${frames[$index]}\e[0m"
sleep 0.5
    done
}

# Menjalankan animasi loading

# Menampilkan pesan setelah animasi selesai
function Loading_Succes() {
clear
echo -e  "\033[5;32mSucces\033[0m"
sleep 2
clear
}


function Daftar_User_Vless() {
grep -E "^### " "/etc/vless/.vless.db" | awk '{print $2, $3, $5"GB", $6"IP"}' | column -t | sort | uniq
}

function change_vmess_quota() {
clear
baris_panjang
echo -e "${Cyan} USERNAME ${Xark} "
Daftar_User_Vless
baris_panjang
echo ""
read -p "Input Username : " user
if ! awk -v u="$user" '$1=="###" && $2==u {found=1} END{exit !found}' /etc/vless/.vless.db; then
  Sanz_Banner
  baris_panjang
  echo -e "${Red} Username tidak ditemukan ${Xark}"
  baris_panjang
  Sc_Credit
fi
baris_panjang
  quota_file="/etc/vless/${user}"

  # Validasi apakah file kuota sudah ada
  if [ -e "$quota_file" ]; then
    current_quota=$(cat "$quota_file")
    echo ""
    baris_panjang
    echo -e "${Cyan} BEFORE ${Xark} "
    echo ""
    echo -e "${yellow} Username    : $user ${Xark} "
    echo -e "${yellow} Quota       : $((current_quota / 1024 / 1024 / 1024)) GB ${Xark}"
    echo ""
    baris_panjang
echo ""
echo ""
read -p "Input New Quota  : " new_quota
echo -e ""
Loading_Animasi
Loading_Succes

    # Validasi jika masukan kosong atau tidak valid

    if [[ -z "$new_quota" || ! "$new_quota" =~ ^[0-9]+$ ]]; then
baris_panjang
echo -e "${Red} Wrong Input Methode ${Xark} "
baris_panjang
    else

      # Konversi kuota ke byte
      new_quota_bytes=$((new_quota * 1024 * 1024 * 1024))
      echo "${new_quota_bytes}" > "${quota_file}"
      old_exp=$(awk -v u="$user" '$1=="###" && $2==u {print $3; exit}' /etc/vless/.vless.db)
uuid=$(awk -v u="$user" '$1=="###" && $2==u {print $4; exit}' /etc/vless/.vless.db)
iplimit=$(awk -v u="$user" '$1=="###" && $2==u {print $6; exit}' /etc/vless/.vless.db)

sed -i "/^### ${user} /d" /etc/vless/.vless.db
echo "### ${user} ${old_exp} ${uuid} ${new_quota} ${iplimit}" >> /etc/vless/.vless.db
Sanz_Banner
baris_panjang
echo -e "${GreenBe}Succesfully ${Xark} "
echo -e ""
echo -e "${Cyan} AFTER ${Xark} "
echo -e ""
echo -e "${yellow}New Quota: $new_quota GB ${Xark} "
echo -e "${yellow}Username : $user ${Xark} "
echo -e ""
baris_panjang
Sc_Credit

      
}

# Panggil fungsi untuk mengganti kuota VMess
change_vmess_quota
