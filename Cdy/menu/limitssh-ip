#!/bin/bash

function send_log() {
    CHATID=$(grep -E "^#bot# " "/etc/bot/.bot.db" | cut -d ' ' -f 3)
    KEY=$(grep -E "^#bot# " "/etc/bot/.bot.db" | cut -d ' ' -f 2)
    TIME="10"
    URL="https://api.telegram.org/bot$KEY/sendMessage"
    TEXT="
<code>────────────────────</code>
<b>⚠️ NOTIFICATIONS MULTI LOGIN SSH⚠️</b>
<code>────────────────────</code>
<code>Username          : </code><code>$user</code>
<code>Limit IP            : </code><code>${iplimit}</code>
<code>User Login         : </code><code>${cekcek}</code>
<code>Akun Locked       : </code><code>15 Menit</code>
<code>────────────────────</code>
"
    curl -s --max-time $TIME -d "chat_id=$CHATID&disable_web_page_preview=1&text=$TEXT&parse_mode=html" $URL >/dev/null
}

function send_wa_gateway() {
    WA_API=$(cat /etc/bot/.wa_api 2>/dev/null)
    WA_TARGET=$(cat /etc/bot/.wa_target 2>/dev/null)
    API_KEY=$(cat /etc/bot/.api_key 2>/dev/null)

    MESSAGE="⚠️ MULTI LOGIN SSH
Username: $user
Limit IP: $iplimit
User Login: $cekcek
Locked: 15 Menit"

    [[ -z "$WA_API" || -z "$WA_TARGET" || -z "$API_KEY" ]] && return

    curl -s --max-time 10 \
      -X POST "$WA_API" \
      -H "Content-Type: application/json" \
      -H "x-api-key: $API_KEY" \
      -d "{\"to\":\"$WA_TARGET\",\"message\":\"$MESSAGE\"}" >/dev/null
}

clear

mulog=$(cek-ssh)
date=$(date)
data=( `ls /etc/kyt/limit/ssh/ip`)

for user in "${data[@]}"
do
    iplimit=$(cat /etc/kyt/limit/ssh/ip/$user)
    cekcek=$(echo "$mulog" | awk -F' - ' -v u="$user" '{gsub(/\047/, "", $2); if ($2==u) print $3}' | cut -d: -f1 | sort -u | wc -l)

    if [[ $iplimit -gt 0 && $cekcek -gt $iplimit ]]; then
        passwd -l "$user" > /dev/null
        send_log
        send_wa_gateway
        echo "passwd -u $user" | at now + 15 minutes > /dev/null
    fi

    sleep 0.1
done

echo > /dev/null
