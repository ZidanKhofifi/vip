#!/bin/bash

Login="$1"
Pass="$2"
iplimit="$3"
masaaktif="$4"

if [[ -z "$Login" || -z "$Pass" || -z "$iplimit" || -z "$masaaktif" ]]; then
  echo '{"status":"error","message":"Usage: add-ssh-api username password iplimit expired_days"}'
  exit 1
fi

domain=$(cat /etc/xray/domain)
IP=$(curl -sS ipv4.icanhazip.com)
ISP=$(cat /etc/xray/isp 2>/dev/null)
CITY=$(cat /etc/xray/city 2>/dev/null)

if id "$Login" >/dev/null 2>&1; then
  echo "{\"status\":\"error\",\"message\":\"User $Login already exists\"}"
  exit 1
fi

if [[ "$iplimit" -gt 0 ]]; then
  mkdir -p /etc/kyt/limit/ssh/ip/
  echo "$iplimit" > /etc/kyt/limit/ssh/ip/$Login
fi

useradd -e "$(date -d "$masaaktif days" +"%Y-%m-%d")" -s /bin/false -M "$Login"
echo -e "$Pass\n$Pass\n" | passwd "$Login" >/dev/null 2>&1

hariini=$(date +"%Y-%m-%d")
expi=$(date -d "$masaaktif days" +"%Y-%m-%d")
expe=$(date -d "$masaaktif days" +"%d %b, %Y")
created=$(date +"%d %b, %Y")

mkdir -p /etc/ssh
touch /etc/ssh/.ssh.db

sed -i "/^#ssh# $Login /d" /etc/ssh/.ssh.db
echo "#ssh# $Login $Pass 0 $iplimit $expe" >> /etc/ssh/.ssh.db

cat > /var/www/html/ssh-$Login.txt <<END
SSH OPENVPN ACCOUNT
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Username      : $Login
Password      : $Pass
Domain        : $domain
IP VPS        : $IP
ISP           : $ISP
City          : $CITY
Limit IP      : $iplimit
Expired       : $expe
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SSH WS        : $domain:80@$Login:$Pass
SSH SSL       : $domain:443@$Login:$Pass
UDP Custom    : $domain:1-65535@$Login:$Pass
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Payload WS:
GET / HTTP/1.1[crlf]Host: [host][crlf]Connection: Upgrade[crlf]User-Agent: [ua][crlf]Upgrade: websocket[crlf][crlf]

Payload Enhanced:
PATCH / HTTP/1.1[crlf]Host: $domain[crlf]Host: bug.com[crlf]Connection: Upgrade[crlf]User-Agent: [ua][crlf]Upgrade: websocket[crlf][crlf]
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
END

cat <<EOF
{
  "status": "success",
  "username": "$Login",
  "password": "$Pass",
  "domain": "$domain",
  "ip": "$IP",
  "isp": "$ISP",
  "city": "$CITY",
  "ip_limit": "$iplimit",
  "expired_days": "$masaaktif",
  "expired_date": "$expi",
  "ssh_ws": "$domain:80@$Login:$Pass",
  "ssh_ssl": "$domain:443@$Login:$Pass",
  "udp_custom": "$domain:1-65535@$Login:$Pass",
  "account_url": "https://$domain:81/ssh-$Login.txt",
  "payload_ws": "GET / HTTP/1.1[crlf]Host: [host][crlf]Connection: Upgrade[crlf]User-Agent: [ua][crlf]Upgrade: websocket[crlf][crlf]",
  "payload_enhanced": "PATCH / HTTP/1.1[crlf]Host: $domain[crlf]Host: bug.com[crlf]Connection: Upgrade[crlf]User-Agent: [ua][crlf]Upgrade: websocket[crlf][crlf]"
}
EOF
