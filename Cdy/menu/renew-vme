#!/bin/bash

yellow="\033[0;33m"
ungu="\033[0;35m"
Red="\033[91;1m"
Cyan="\033[96;1m"
Xark="\033[0m"
BlueCyan="\033[5;36m"
WhiteBe="\033[5;37m"
GreenBe="\033[5;32m"

baris_panjang() {
  echo -e "${BlueCyan} ——————————————————————————————————— ${Xark}"
}

vip_Banner() {
  clear
  baris_panjang
  echo -e "${ungu}         ZIDAN TUNNELING      ${Xark}"
  baris_panjang
}

Sc_Credit() {
  sleep 1
  baris_panjang
  echo -e "${ungu}  Terimakasih Telah Menggunakan ${Xark}"
  echo -e "${ungu}          Script Credit ${Xark}"
  echo -e "${ungu}        ZIDAN TUNNELING ${Xark}"
  baris_panjang
  exit 1
}

clear
mkdir -p /etc/vmess
touch /etc/vmess/.vmess.db

NUMBER_OF_CLIENTS=$(grep -c -E "^### " /etc/vmess/.vmess.db 2>/dev/null)

if [[ "$NUMBER_OF_CLIENTS" == "0" ]]; then
  vip_Banner
  echo ""
  echo -e "${Red} Tidak ada akun VMess !!! ${Xark}"
  echo ""
  Sc_Credit
fi

vip_Banner
echo -e "${yellow}          RENEW VMESS     ${Xark}"
baris_panjang
echo -e "${WhiteBe}  User       Expired  ${Xark}"
baris_panjang
grep -E "^### " /etc/vmess/.vmess.db | awk '{print $2, $3}' | column -t | sort | uniq
baris_panjang
echo ""

read -rp " Input Username   : " user

if [[ -z "$user" ]]; then
  menu
  exit 0
fi

if ! grep -qwE "^### $user " /etc/vmess/.vmess.db; then
  vip_Banner
  echo ""
  echo -e "${Red} Username tidak ditemukan: $user ${Xark}"
  echo ""
  Sc_Credit
fi

read -rp " Expired tambah hari : " masaaktif
read -rp " Limit User (GB)     : " Quota
read -rp " Limit User (IP)     : " iplim

old_exp=$(grep -wE "^### $user " /etc/vmess/.vmess.db | awk '{print $3}' | sort | uniq)
uuid=$(grep -wE "^### $user " /etc/vmess/.vmess.db | awk '{print $4}' | sort | uniq)

today=$(date +%Y-%m-%d)

if [[ $(date -d "$old_exp" +%s) -lt $(date -d "$today" +%s) ]]; then
  base_date="$today"
else
  base_date="$old_exp"
fi

new_exp=$(date -d "$base_date + $masaaktif days" +"%Y-%m-%d")

rm -f "/etc/kyt/limit/vmess/ip/$user"
rm -f "/etc/vmess/$user"

mkdir -p /etc/kyt/limit/vmess/ip
echo "$iplim" > "/etc/kyt/limit/vmess/ip/$user"

if [[ -z "$Quota" ]]; then
  Quota="0"
fi

c=$(echo "$Quota" | sed 's/[^0-9]*//g')
d=$((c * 1024 * 1024 * 1024))

if [[ "$c" != "0" ]]; then
  echo "$d" > "/etc/vmess/$user"
fi

sed -i "/^### $user /d" /etc/vmess/.vmess.db
echo "### $user $new_exp $uuid $Quota $iplim" >> /etc/vmess/.vmess.db

if xray run -test -config /etc/xray/config.json >/dev/null 2>&1; then
  systemctl restart xray >/dev/null 2>&1
else
  vip_Banner
  echo -e "${Red} Config Xray error. Cek /etc/xray/config.json ${Xark}"
  Sc_Credit
fi

vip_Banner
baris_panjang
echo -e "${GreenBe} Successfully Renewed ${Xark}"
echo ""
echo -e "${yellow} Client Name   : $user ${Xark}"
echo -e "${yellow} Old Expired   : $old_exp ${Xark}"
echo -e "${yellow} New Expired   : $new_exp ${Xark}"
echo -e "${yellow} User Quota    : $Quota GB ${Xark}"
echo -e "${yellow} User Limit IP : $iplim Device ${Xark}"
echo ""
baris_panjang
Sc_Credit
