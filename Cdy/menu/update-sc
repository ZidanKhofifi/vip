#!/bin/bash

REPO="https://raw.githubusercontent.com/ZidanKhofifi/vip/main/"

clear
echo "———————————————————————————————————————"
echo "              UPDATE SCRIPT"
echo "———————————————————————————————————————"
echo ""

echo "[1/5] Update menu command..."
cd /root || exit 1
rm -rf menu menu.zip

wget -q -O menu.zip "${REPO}Cdy/menu.zip"

if [[ ! -s menu.zip ]]; then
  echo "Gagal download menu.zip"
  exit 1
fi

unzip -o menu.zip >/dev/null 2>&1

chmod +x menu/*

cp -rf menu/* /usr/local/sbin/

chmod +x /usr/local/sbin/*

rm -rf menu menu.zip

echo "[2/5] Update config..."

wget -q -O /etc/default/dropbear "${REPO}Cfg/dropbear.conf"
wget -q -O /usr/bin/tun.conf "${REPO}Cfg/tun.conf"
wget -q -O /etc/nginx/nginx.conf "${REPO}Cfg/nginx.conf"
wget -q -O /etc/nginx/conf.d/xray.conf "${REPO}Cfg/xray.conf"
wget -q -O /etc/haproxy/haproxy.cfg "${REPO}Cfg/haproxy.cfg"

echo "[3/5] Stop service..."

systemctl stop dropbear 2>/dev/null
systemctl stop ws 2>/dev/null

pkill -9 dropbear 2>/dev/null
pkill -9 ws 2>/dev/null

sleep 2

echo "[4/5] Update binary..."

wget -q -O /usr/sbin/dropbear "${REPO}Fls/dropbear2019"
chmod +x /usr/sbin/dropbear

wget -q -O /usr/bin/ws "${REPO}Fls/ws"
chmod +x /usr/bin/ws

echo "[5/5] Restart service..."

systemctl daemon-reload

systemctl restart dropbear 2>/dev/null || /etc/init.d/dropbear restart

systemctl restart ws 2>/dev/null || true

xray run -test -config /etc/xray/config.json >/dev/null 2>&1 && systemctl restart xray

nginx -t >/dev/null 2>&1 && systemctl restart nginx

haproxy -c -f /etc/haproxy/haproxy.cfg >/dev/null 2>&1 && systemctl restart haproxy

echo ""
echo "———————————————————————————————————————"
echo "Update script selesai"
echo "———————————————————————————————————————"

echo ""
echo "VERSI DROPBEAR:"
dropbear -V

echo ""
echo "STATUS API:"
systemctl status zidan-api --no-pager | head -n 5

echo ""
read -n 1 -s -r -p "Press any key to back"

menu