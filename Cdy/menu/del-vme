#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
yellow="\033[0;33m"
ungu="\033[0;35m"
Red="\033[91;1m"
Xark="\033[0m"
BlueCyan="\033[5;36m"
WhiteBe="\033[5;37m"
GreenBe="\033[5;32m"

function baris_panjang() {
  echo -e "${BlueCyan} ——————————————————————————————————— ${Xark}"
}

function vip_Banner() {
  clear
  baris_panjang
  echo -e "${ungu}           ZIDAN TUNNELING      ${Xark}"
  baris_panjang
}

function Sc_Credit() {
  sleep 1
  baris_panjang
  echo -e "${ungu}  Terimakasih Telah Menggunakan ${Xark}"
  echo -e "${ungu}          Script Credit ${Xark}"
  echo -e "${ungu}          ZIDAN TUNNELING ${Xark}"
  baris_panjang
  exit 1
}

clear
mkdir -p /etc/vmess
touch /etc/vmess/.vmess.db

NUMBER_OF_CLIENTS=$(grep -c -E "^### " "/etc/vmess/.vmess.db" 2>/dev/null)

if [[ "$NUMBER_OF_CLIENTS" == "0" ]]; then
  vip_Banner
  echo ""
  echo -e "${Red} Tidak ada akun VMess !!! ${Xark}"
  echo ""
  Sc_Credit
fi

vip_Banner
echo -e "${ungu}           DELETE VMESS      ${Xark}"
baris_panjang
echo -e "${WhiteBe}  User       Expired  ${Xark}"
baris_panjang
grep -E "^### " "/etc/vmess/.vmess.db" | awk '{print $2, $3}' | column -t | sort | uniq
baris_panjang
echo ""

read -rp " Input Username    : " user

if [[ -z "$user" ]]; then
  menu
fi

if ! awk -v u="$user" '$1=="###" && $2==u {found=1} END{exit !found}' /etc/vmess/.vmess.db; then
  clear
  vip_Banner
  echo ""
  echo -e "${Red} Username tidak ditemukan: $user ${Xark}"
  echo ""
  Sc_Credit
fi

exp=$(awk -v u="$user" '$1=="###" && $2==u {print $3; exit}' /etc/vmess/.vmess.db)
uuid=$(awk -v u="$user" '$1=="###" && $2==u {print $4; exit}' /etc/vmess/.vmess.db)

python3 <<PY
import json

path = "/etc/xray/config.json"
uuid = "$uuid"
user = "$user"

with open(path) as f:
    data = json.load(f)

for inbound in data.get("inbounds", []):
    if inbound.get("protocol") == "vmess":
        clients = inbound.get("settings", {}).get("clients", [])
        inbound.setdefault("settings", {})["clients"] = [
            c for c in clients
            if c.get("id") != uuid and c.get("email") != user
        ]

with open(path, "w") as f:
    json.dump(data, f, indent=2)
PY

sed -i "/^### $user /d" /etc/vmess/.vmess.db

rm -f "/etc/vmess/$user"
rm -f "/etc/kyt/limit/vmess/ip/$user"
rm -f "/var/www/html/vmess-$user.txt"

if xray run -test -config /etc/xray/config.json >/dev/null 2>&1; then
  systemctl restart xray >/dev/null 2>&1
else
  clear
  vip_Banner
  echo -e "${Red} Config Xray error, akun tidak direstart. Cek /etc/xray/config.json ${Xark}"
  Sc_Credit
fi

clear
vip_Banner
baris_panjang
echo -e "${GreenBe} Successfully Deleted ${Xark}"
echo ""
echo -e "${yellow} Client Name : $user ${Xark}"
echo -e "${yellow} Expired On  : $exp ${Xark}"
echo ""
baris_panjang
Sc_Credit