#!/bin/bash

today_seconds=$(date +%s)
today_date=$(date +"%d-%m-%Y")

deleted=()
count=0

while IFS=: read -r username userexp; do
  [[ -z "$username" || -z "$userexp" ]] && continue
  [[ "$userexp" == "" ]] && continue

  expire_seconds=$((userexp * 86400))

  if [[ "$expire_seconds" -lt "$today_seconds" ]]; then
    exp_date=$(date -d "@$expire_seconds" +"%d %b %Y")

    userdel "$username" >/dev/null 2>&1

    rm -f "/etc/ssh/$username"
    rm -f "/etc/kyt/limit/ssh/ip/$username"
    rm -f "/var/www/html/ssh-$username.txt"

    sed -i "/^#ssh# $username /d" /etc/ssh/.ssh.db 2>/dev/null

    deleted+=("{\"username\":\"$username\",\"expired\":\"$exp_date\"}")
    count=$((count + 1))
  fi
done < <(cat /etc/shadow | cut -d: -f1,8 | sed '/:$/d')

echo '{'
echo '  "status": "success",'
echo '  "deleted_count": '"$count"','
echo '  "deleted_users": ['

for i in "${!deleted[@]}"; do
  [[ "$i" -gt 0 ]] && echo ','
  echo -n "    ${deleted[$i]}"
done

echo ''
echo '  ],'
echo '  "date": "'"$today_date"'"'
echo '}'