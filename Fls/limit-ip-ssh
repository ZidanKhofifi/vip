#!/bin/bash

LOCK_TTL=60
TMP_LOGIN="/tmp/cek_ssh_login.txt"

send_log() {
    CHATID=$(grep -E "^#bot# " "/etc/bot/.bot.db" | cut -d ' ' -f 3)
    KEY=$(grep -E "^#bot# " "/etc/bot/.bot.db" | cut -d ' ' -f 2)
    TIME="10"
    URL="https://api.telegram.org/bot$KEY/sendMessage"

    [[ -z "$CHATID" || -z "$KEY" ]] && return

    TEXT="
<code>────────────────────</code>
<b>⚠️ MULTI LOGIN SSH DETECTED ⚠️</b>
<code>────────────────────</code>
<code>Username   : </code><code>$user</code>
<code>Limit IP   : </code><code>$iplimit</code>
<code>User Login: </code><code>$cekcek</code>
<code>Status    : </code><code>Multi Login Detected</code>
<code>────────────────────</code>
"

    curl -s --max-time "$TIME" \
      -d "chat_id=$CHATID&disable_web_page_preview=1&text=$TEXT&parse_mode=html" \
      "$URL" >/dev/null 2>&1
}

send_wa_gateway() {
    WA_API=$(cat /etc/bot/.wa_api 2>/dev/null)
    WA_TARGET=$(cat /etc/bot/.wa_target 2>/dev/null)
    API_KEY=$(cat /etc/bot/.api_key 2>/dev/null)

    [[ -z "$WA_API" || -z "$WA_TARGET" || -z "$API_KEY" ]] && return

    MESSAGE="⚠️ MULTI LOGIN SSH DETECTED
Username: $user
Limit IP: $iplimit
User Login: $cekcek
Status: Multi Login Detected"

    JSON=$(jq -n \
      --arg to "$WA_TARGET" \
      --arg message "$MESSAGE" \
      '{to:$to,message:$message}')

    curl -s --max-time 15 \
      -X POST "$WA_API" \
      -H "Content-Type: application/json" \
      -H "x-api-key: $API_KEY" \
      -d "$JSON" >/dev/null 2>&1
}

lock_expired() {
    local file="$1"

    if [[ ! -f "$file" ]]; then
        return 0
    fi

    local now
    local modified
    local age

    now=$(date +%s)
    modified=$(stat -c %Y "$file" 2>/dev/null || echo 0)
    age=$((now - modified))

    if [[ "$age" -ge "$LOCK_TTL" ]]; then
        rm -f "$file"
        return 0
    fi

    return 1
}

count_login_from_file() {
    local username="$1"

    awk -F' - ' -v u="$username" '
    {
        gsub(/\047/, "", $2)
        if ($2 == u) print $1
    }' "$TMP_LOGIN" | sort -u | wc -l
}

# Anti double-run
LOCK_RUN="/tmp/limit-ip-ssh-running.lock"

if [[ -f "$LOCK_RUN" ]]; then
    oldpid=$(cat "$LOCK_RUN" 2>/dev/null)
    if [[ -n "$oldpid" ]] && kill -0 "$oldpid" 2>/dev/null; then
        exit 0
    fi
fi

echo $$ > "$LOCK_RUN"
trap 'rm -f "$LOCK_RUN" "$TMP_LOGIN"' EXIT

# Jalankan cek-ssh cukup 1x
timeout 20 cek-ssh-limit > "$TMP_LOGIN" 2>/dev/null

if [[ ! -s "$TMP_LOGIN" ]]; then
    exit 0
fi

for file in /etc/kyt/limit/ssh/ip/*; do
    [[ -f "$file" ]] || continue

    user=$(basename "$file")
    iplimit=$(cat "$file" 2>/dev/null || echo 0)
    LOCK_FILE="/tmp/limitssh_${user}.lock"

    [[ "$iplimit" =~ ^[0-9]+$ ]] || iplimit=0

    cekcek=$(count_login_from_file "$user")

    if [[ "$iplimit" -gt 0 && "$cekcek" -gt "$iplimit" ]]; then
        if lock_expired "$LOCK_FILE"; then
            send_log
            send_wa_gateway
            touch "$LOCK_FILE"
        fi
    fi
done

exit 0